{
  "login": {
    "request": {
      "email": "user@example.com",
      "password": "password123"
    },
    "response": {
      "user": {
        "uid": "user_uid",
        "email": "user@example.com"
      },
      "token": "auth_token_example"
    }
  },
  "register": {
    "request": {
      "email": "newuser@example.com",
      "password": "newpassword123",
      "name": "New User"
    },
    "response": {
      "user": {
        "uid": "new_user_uid",
        "email": "newuser@example.com"
      }
    }
  }
}
